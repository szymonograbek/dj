# Create an app at https://developer.spotify.com/dashboard
# Add this exact Redirect URI in the Spotify app settings:
# http://127.0.0.1:8888/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Filled by ./spotify.js playlist init, or set manually to the only writable playlist.
SPOTIFY_DJ_PLAYLIST_ID=
SPOTIFY_DJ_PLAYLIST_NAME=Personal DJ

# Private memory location. Can be an absolute path in iCloud Drive.
# Example: /Users/you/Library/Mobile Documents/com~apple~CloudDocs/spotify-dj-memory
MEMORY_DIR=memory

# Create an API account at https://www.last.fm/api/account/create
# Read-only commands only need API key + username.
LASTFM_API_KEY=
LASTFM_USERNAME=
